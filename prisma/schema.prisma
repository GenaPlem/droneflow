// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  planned
  ready_to_shoot
  filmed
  editing
  delivered
}

enum ShotType {
  orbit
  reveal
  top_down
  tracking
  custom
}

enum MediaType {
  image
  video
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  location    String
  shootDate   DateTime?
  description String?
  status      ProjectStatus @default(planned)
  featured    Boolean       @default(false)
  isPublic    Boolean       @default(false)
  archived    Boolean       @default(false)

  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  shots       Shot[]
  media       Media[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Shot {
  id         String   @id @default(cuid())
  title      String
  type       ShotType
  notes      String?
  completed  Boolean  @default(false)
  order      Int

  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Media {
  id         String    @id @default(cuid())
  type       MediaType
  url        String
  caption    String?
  isBestShot Boolean   @default(false)

  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
}
